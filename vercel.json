{
  "version": 2,
  "builds": [
    { "src": "main.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/main.py" },
    { "src": "/health", "dest": "/main.py" },
    { "src": "/docs", "dest": "/main.py" },
    { "src": "/openapi.json", "dest": "/main.py" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}

{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/main.py" },
    { "source": "/health", "destination": "/main.py" },
    { "source": "/docs", "destination": "/main.py" },
    { "source": "/openapi.json", "destination": "/main.py" }
  ]
}
